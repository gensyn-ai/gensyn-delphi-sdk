    "prediction-markets",
    "agents",
    "sdk",
    "on-chain"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@vitest/ui": "4.0.18",
    "eslint": "^10.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.44.1",
    "dotenv": "^16.4.0",
    "viem": "^2.21.0"
