{
  "name": "@gensyn-ai/gensyn-delphi-sdk",
  "version": "0.1.0",
  "description": "SDK for agents to interact with the Delphi on-chain prediction market platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/gensyn-ai/gensyn-delphi-sdk.git"
  },
  "bugs": {
    "url": "https://security.delphi.fyi",
    "email": "security@gensyn.ai"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npx --yes -p typescript tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
